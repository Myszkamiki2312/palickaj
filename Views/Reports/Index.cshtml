@model ReportViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Raport";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Raport operacyjny</span>
        <h1 class="page-title">Przeglad techniczny backlogu</h1>
        <p class="page-copy">Widok podsumowuje ryzyka, rozklad zadan i integracje wymagajace uwagi. To dobra sekcja do pokazania umiejetnosci analitycznych.</p>
    </div>
</section>

<section class="metric-grid">
    @foreach (var card in Model.Summary)
    {
        <article class="metric-card @card.AccentClass">
            <p class="metric-label">@card.Title</p>
            <h2 class="metric-value">@card.Value</h2>
            <p class="metric-hint">@card.Hint</p>
        </article>
    }
</section>

<div class="page-grid">
    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Moduly</span>
                <h2 class="section-title">Nasycenie zadaniami</h2>
            </div>
        </div>
        <div class="bar-stack">
            @foreach (var module in Model.ModuleHealth)
            {
                <div class="bar-row">
                    <div class="bar-meta">
                        <strong>@module.Module</strong>
                        <span>@module.Tickets zgloszen</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style=@($"width:{module.Progress.ToString(CultureInfo.InvariantCulture)}%")></div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Rekomendacje</span>
                <h2 class="section-title">Dalsze kroki</h2>
            </div>
        </div>
        <ol class="recommendation-list">
            @foreach (var item in Model.Recommendations)
            {
                <li>@item</li>
            }
        </ol>
    </section>
</div>

<div class="page-grid">
    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Po terminie</span>
                <h2 class="section-title">Zgloszenia wymagajace akcji</h2>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table data-table">
                <thead>
                    <tr>
                        <th>Numer</th>
                        <th>Klient</th>
                        <th>Temat</th>
                        <th>Priorytet</th>
                        <th>Termin</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OverdueTickets.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">Brak zgloszen po terminie.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var ticket in Model.OverdueTickets)
                        {
                            <tr>
                                <td>@ticket.Number</td>
                                <td>@ticket.Client</td>
                                <td>@ticket.Title</td>
                                <td>@ticket.Priority</td>
                                <td>@ticket.DueAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Integracje</span>
                <h2 class="section-title">Obszary podwyzszonego ryzyka</h2>
            </div>
        </div>
        <div class="stack-list">
            @foreach (var integration in Model.RiskyIntegrations)
            {
                <div class="list-row">
                    <div>
                        <div class="list-title">@integration.Name</div>
                        <div class="list-subtitle">@integration.Client - @integration.Owner</div>
                    </div>
                    <div class="list-meta">
                        <span class="chip @(integration.Status == "Wymaga reakcji" ? "chip-red" : "chip-gold")">@integration.Status</span>
                        <span class="tiny-note">@integration.ErrorCount bledow - @integration.SuccessRate.ToString("0.#")%</span>
                    </div>
                </div>
            }
        </div>
    </section>
</div>
