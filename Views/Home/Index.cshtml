@model DashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-panel">
    <div>
        <span class="eyebrow">Portfolio demo w C# i .NET</span>
        <h1 class="hero-title">Centrum serwisowe dla klientow ERP</h1>
        <p class="hero-copy">
            Aplikacja pokazuje obsluge zgloszen, klientow, integracji i raportow operacyjnych dla wdrozen systemow klasy ERP.
        </p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-primary btn-hero" asp-controller="Tickets" asp-action="Create">Dodaj zgloszenie</a>
        <a class="btn btn-outline-light btn-ghost" asp-controller="Reports" asp-action="Index">Raport techniczny</a>
    </div>
</section>

<section class="metric-grid">
    @foreach (var card in Model.Metrics)
    {
        <article class="metric-card @card.AccentClass">
            <p class="metric-label">@card.Title</p>
            <h2 class="metric-value">@card.Value</h2>
            <p class="metric-hint">@card.Hint</p>
        </article>
    }
</section>

<div class="page-grid">
    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Obciazenie</span>
                <h2 class="section-title">Moduly z najwieksza liczba zadan</h2>
            </div>
            <a class="text-link" asp-controller="Tickets" asp-action="Index">Zobacz backlog</a>
        </div>
        <div class="bar-stack">
            @foreach (var module in Model.ModuleWorkload)
            {
                <div class="bar-row">
                    <div class="bar-meta">
                        <strong>@module.Module</strong>
                        <span>@module.Tickets zgloszen</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style=@($"width:{module.Progress.ToString(CultureInfo.InvariantCulture)}%")></div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Kolejka priorytetowa</span>
                <h2 class="section-title">Najwazniejsze zgloszenia</h2>
            </div>
        </div>
        <div class="stack-list">
            @foreach (var ticket in Model.PriorityQueue)
            {
                <a class="list-row list-row-link" asp-controller="Tickets" asp-action="Details" asp-route-id="@ticket.Id">
                    <div>
                        <div class="list-title">@ticket.Number - @ticket.Title</div>
                        <div class="list-subtitle">@ticket.Client - @ticket.Module</div>
                    </div>
                    <div class="list-meta">
                        <span class="chip @(ticket.Priority == "Krytyczny" ? "chip-red" : ticket.Priority == "Wysoki" ? "chip-gold" : "chip-blue")">@ticket.Priority</span>
                        <span class="tiny-note">@ticket.DueAt.ToString("dd.MM HH:mm")</span>
                    </div>
                </a>
            }
        </div>
    </section>
</div>

<div class="page-grid">
    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Integracje</span>
                <h2 class="section-title">Stan przeplywow i API</h2>
            </div>
            <a class="text-link" asp-controller="Integrations" asp-action="Index">Pelna lista</a>
        </div>
        <div class="stack-list">
            @foreach (var integration in Model.IntegrationHealth)
            {
                <div class="list-row">
                    <div>
                        <div class="list-title">@integration.Name</div>
                        <div class="list-subtitle">@integration.Client - @integration.Owner</div>
                    </div>
                    <div class="list-meta">
                        <span class="chip @(integration.Status == "Wymaga reakcji" ? "chip-red" : integration.Status == "Monitorowana" ? "chip-gold" : "chip-green")">@integration.Status</span>
                        <span class="tiny-note">@integration.SuccessRate.ToString("0.#")%</span>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="content-card">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Terminy</span>
                <h2 class="section-title">Nadchodzace deadliny</h2>
            </div>
        </div>
        <div class="stack-list">
            @foreach (var deadline in Model.UpcomingDeadlines)
            {
                <div class="list-row">
                    <div>
                        <div class="list-title">@deadline.Number</div>
                        <div class="list-subtitle">@deadline.Title</div>
                    </div>
                    <div class="list-meta">
                        <span class="tiny-note">@deadline.Client</span>
                        <strong>@deadline.DueAt.ToString("dd.MM HH:mm")</strong>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

<section class="content-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Klienci</span>
            <h2 class="section-title">Puls aktywnych wdrozen</h2>
        </div>
        <a class="text-link" asp-controller="Clients" asp-action="Index">Przegladaj konta</a>
    </div>
    <div class="pulse-grid">
        @foreach (var client in Model.ClientPulse)
        {
            <a class="pulse-card" asp-controller="Clients" asp-action="Details" asp-route-id="@client.Id">
                <div class="pulse-top">
                    <strong>@client.Name</strong>
                    <span class="chip chip-outline">@client.SupportPlan</span>
                </div>
                <div class="pulse-stats">
                    <div>
                        <span class="stat-label">Otwarte</span>
                        <strong>@client.OpenTickets</strong>
                    </div>
                    <div>
                        <span class="stat-label">Uzytkownicy</span>
                        <strong>@client.ActiveUsers</strong>
                    </div>
                    <div>
                        <span class="stat-label">Integracje</span>
                        <strong>@client.IntegrationHealth.ToString("0.#")%</strong>
                    </div>
                </div>
                <span class="tiny-note">Ostatni przeglad: @client.LastReviewAt.ToString("dd.MM.yyyy")</span>
            </a>
        }
    </div>
</section>
